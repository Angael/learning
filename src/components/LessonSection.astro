---
type Props = {
  title: string;
  variant?: 'checkpoint' | 'warning';
};

const { title, variant } = Astro.props;
const Tag = variant === 'warning' ? 'aside' : 'section';
---

<Tag class={variant}>
  <h2 set:html={title} />
  <slot />
</Tag>

<style>
  section,
  aside {
    min-width: 0;
    margin: 16px 0;
    padding: 22px;
    border: 1px solid var(--line);
    border-radius: 24px;
    background: rgba(255, 255, 255, .82);
    box-shadow: 0 18px 60px rgba(35, 40, 60, .06);
  }

  h2 {
    margin: 0 0 12px;
    font-size: 1.35rem;
    letter-spacing: -.02em;
  }

  .checkpoint {
    border-color: rgba(17, 97, 73, .35);
    background: rgba(235, 250, 244, .76);
  }

  .checkpoint h2 {
    color: var(--ok);
  }

  .warning {
    border-color: rgba(146, 64, 14, .35);
    background: rgba(255, 247, 237, .82);
  }

  .warning h2 {
    color: var(--warn);
  }

  @media (max-width: 759px) {
    section,
    aside {
      margin-right: -10px;
      margin-left: -10px;
      padding: 18px 14px;
      border-right: 0;
      border-left: 0;
      border-radius: 16px;
      box-shadow: 0 10px 36px rgba(35, 40, 60, .05);
    }

    h2 {
      font-size: 1.25rem;
    }
  }

  @media (min-width: 760px) {
    section,
    aside {
      padding: 28px;
    }
  }
</style>
