---
import { existsSync } from 'node:fs';
import { join } from 'node:path';
import BaseLayout from './BaseLayout.astro';

type Props = {
  title: string;
  heading: string;
  lede: string;
  backHref: string;
  backLabel: string;
};

const { title, heading, lede, backHref, backLabel } = Astro.props;
const currentPath = Astro.url.pathname.endsWith('/') ? Astro.url.pathname : `${Astro.url.pathname}/`;
const notesPath = join(process.cwd(), 'src/pages', currentPath, 'notes.md');
const hasNotes = existsSync(notesPath);
---

<BaseLayout title={title}>
  <main class="lesson-shell">
    <nav class="lesson-nav"><a href={backHref}>← {backLabel}</a></nav>

    <header class="lesson-header">
      <h1 class="lesson-title" set:html={heading} />
      <p class="lesson-lede">{lede}</p>
    </header>

    <slot />

    {hasNotes && (
      <aside class="lesson-notes-link">
        <strong>Lesson notes</strong>
        <span>Helper note with checkpoint state, misconceptions, and next hints.</span>
        <a href={`${currentPath}notes/`}>Open notes →</a>
      </aside>
    )}
  </main>
</BaseLayout>

<style is:global>
  .lesson-shell {
    width: min(860px, calc(100% - 32px));
    margin: 0 auto;
    padding: 28px 0 64px;
  }

  .lesson-nav {
    margin-bottom: 32px;
  }

  .lesson-nav a {
    color: var(--muted);
  }

  .lesson-nav a:hover {
    color: var(--accent);
  }

  .lesson-header {
    margin-bottom: 28px;
  }

  .lesson-title {
    max-width: 820px;
    margin: 0 0 12px;
    font-size: clamp(2.35rem, 8vw, 5.2rem);
    line-height: .92;
    letter-spacing: -.065em;
  }

  .lesson-lede {
    max-width: 700px;
    font-size: 1.12rem;
    line-height: 1.6;
  }

  .lesson-shell h3 {
    margin: 22px 0 8px;
    font-size: 1rem;
  }

  .lesson-shell p,
  .lesson-shell li {
    color: var(--muted);
    line-height: 1.6;
  }

  .lesson-shell p {
    margin: 0 0 12px;
  }

  .lesson-shell ul,
  .lesson-shell ol {
    margin: 10px 0 0;
    padding-left: 1.25rem;
  }

  .lesson-shell strong {
    color: var(--text);
  }

  .lesson-notes-link {
    display: grid;
    gap: 4px;
    margin-top: 34px;
    padding: 16px;
    border: 1px solid var(--line);
    border-radius: 16px;
    background: var(--surface);
  }

  .lesson-notes-link span {
    color: var(--muted);
  }

  .lesson-notes-link a {
    margin-top: 4px;
    font-weight: 650;
  }

  .lesson-shell pre {
    max-width: 100%;
    margin: 12px 0 0;
    padding: 16px;
    overflow-x: auto;
    border-radius: 16px;
    background: var(--code);
    color: var(--code-text);
    line-height: 1.55;
  }

  @media (min-width: 760px) {
    .lesson-shell {
      padding-top: 52px;
    }
  }
</style>
