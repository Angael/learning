---
import BaseLayout from './BaseLayout.astro';

type Props = {
  title: string;
  heading: string;
  lede: string;
  backHref: string;
  backLabel: string;
};

const { title, heading, lede, backHref, backLabel } = Astro.props;
---

<BaseLayout title={title}>
  <main class="lesson-shell">
    <nav class="lesson-nav"><a href={backHref}>← {backLabel}</a></nav>

    <header class="lesson-header">
      <h1 class="lesson-title" set:html={heading} />
      <p class="lesson-lede">{lede}</p>
    </header>

    <slot />
  </main>
</BaseLayout>

<style is:global>
  .lesson-shell {
    width: min(860px, calc(100% - 32px));
    margin: 0 auto;
    padding: 28px 0 64px;
  }

  .lesson-nav {
    margin-bottom: 32px;
  }

  .lesson-nav a {
    color: var(--muted);
  }

  .lesson-nav a:hover {
    color: var(--accent);
  }

  .lesson-header {
    margin-bottom: 28px;
  }

  .lesson-title {
    max-width: 820px;
    margin: 0 0 12px;
    font-size: clamp(2.35rem, 8vw, 5.2rem);
    line-height: .92;
    letter-spacing: -.065em;
  }

  .lesson-lede {
    max-width: 700px;
    font-size: 1.12rem;
    line-height: 1.6;
  }

  .lesson-shell h3 {
    margin: 22px 0 8px;
    font-size: 1rem;
  }

  .lesson-shell p,
  .lesson-shell li {
    color: var(--muted);
    line-height: 1.6;
  }

  .lesson-shell p {
    margin: 0 0 12px;
  }

  .lesson-shell ul,
  .lesson-shell ol {
    margin: 10px 0 0;
    padding-left: 1.25rem;
  }

  .lesson-shell strong {
    color: var(--text);
  }

  .lesson-shell pre {
    max-width: 100%;
    margin: 12px 0 0;
    padding: 16px;
    overflow-x: auto;
    border-radius: 16px;
    background: var(--code);
    color: var(--code-text);
    line-height: 1.55;
  }

  @media (min-width: 760px) {
    .lesson-shell {
      padding-top: 52px;
    }
  }
</style>
