---
type Props = {
  tags: string[];
};

const { tags } = Astro.props;
---

<div class="tags">
  {tags.map((tag) => <span set:html={tag} />)}
</div>

<style>
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .tags span {
    padding: 4px 10px;
    border: 1px solid var(--line);
    border-radius: 999px;
    color: var(--muted);
    font-size: .82rem;
  }
</style>
