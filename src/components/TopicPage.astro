---
import '../styles/global.css';
import type { Topic } from '../data/catalog';

type Props = {
  topic: Topic;
};

const { topic } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{topic.title} · Learning</title>
  </head>
  <body>
    <main class="page-shell page-shell--narrow">
      <nav class="page-nav"><a href="/">← All topics</a></nav>
      <h1 class="hero-title hero-title--large">{topic.title}</h1>
      <p>{topic.summary}</p>

      <div class="lesson-list-wrap">
        {topic.lessons.length > 0 ? (
          <ul class="lesson-list" aria-label={`${topic.title} lessons`}>
            {topic.lessons.map((lesson) => (
              <li>
                <a class="lesson-list-card" href={lesson.href}>
                  <strong>{lesson.title}</strong>
                  <span>{lesson.summary}</span>
                </a>
              </li>
            ))}
          </ul>
        ) : (
          <p class="empty-card">No lessons published yet.</p>
        )}
      </div>
    </main>
  </body>
</html>
