---
import LessonSection from './LessonSection.astro';

type Props = {
  id: string;
  copyText: string;
};

const {
  id,
  copyText,
} = Astro.props;

if (!/^learn:[a-z0-9./-]+(?::[a-z0-9-]+)?$/i.test(id)) {
  throw new Error(`ReplyTask id must be a stable learn: identifier; received "${id}"`);
}

const marker = `[${id}]`;
if (!copyText.trimStart().startsWith(marker)) {
  throw new Error(`ReplyTask copyText must start with "${marker}"`);
}
---

<div class="reply-task" data-reply-task data-copy-text={copyText}>
  <LessonSection title="Reply task" variant="checkpoint">
    <button slot="right" class="reply-task__copy" type="button" data-copy-trigger>Copy questions</button>
    <div class="reply-task__content">
      <code class="reply-task__id">{marker}</code>
      <div class="reply-task__body">
        <slot />
      </div>
      <p class="reply-task__status" data-copy-status aria-live="polite"></p>
    </div>
  </LessonSection>
</div>

<script>
  const copyFallback = (text: string, restoreFocus: HTMLElement) => {
    const input = document.createElement('textarea');
    input.value = text;
    input.setAttribute('readonly', '');
    input.style.position = 'fixed';
    input.style.opacity = '0';
    document.body.appendChild(input);
    input.select();
    const copied = document.execCommand('copy');
    input.remove();
    restoreFocus.focus();
    if (!copied) throw new Error('Copy command failed');
  };

  document.querySelectorAll<HTMLElement>('[data-reply-task]').forEach((task) => {
    const button = task.querySelector<HTMLButtonElement>('[data-copy-trigger]');
    const status = task.querySelector<HTMLElement>('[data-copy-status]');
    if (!button || !status || button.dataset.ready === 'true') return;

    button.dataset.ready = 'true';
    button.addEventListener('click', async () => {
      const text = task.dataset.copyText ?? '';
      try {
        if (navigator.clipboard?.writeText) {
          await navigator.clipboard.writeText(text);
        } else {
          copyFallback(text, button);
        }
        status.textContent = 'Copied. Paste this into Discord and write below each answer label.';
        button.textContent = 'Copied';
      } catch {
        status.textContent = 'Copy failed. Select the ID and questions manually.';
        button.textContent = 'Copy questions';
      }
    });
  });
</script>

<style>
  .reply-task__content {
    display: grid;
    gap: 14px;
  }

  .reply-task__copy {
    padding: 9px 12px;
    border: 1px solid var(--line);
    border-radius: 10px;
    background: var(--surface, var(--bg));
    color: var(--text);
    font: inherit;
    font-weight: 700;
    cursor: pointer;
  }

  .reply-task button:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .reply-task__id {
    width: fit-content;
    padding: 4px 7px;
    border-radius: 7px;
    background: var(--code);
    color: var(--code-text);
  }

  .reply-task__body {
    min-width: 0;
  }

  .reply-task__body :global(.shiki) {
    width: 100%;
    min-width: 0;
  }

  .reply-task__body :global(p:last-child),
  .reply-task__body :global(ol:last-child),
  .reply-task__body :global(ul:last-child),
  .reply-task__status {
    margin-bottom: 0;
  }

  .reply-task__status {
    min-height: 1.4em;
    font-size: .9rem;
  }

  @media (max-width: 759px) {
    .reply-task__content {
      gap: 12px;
    }

    .reply-task__copy {
      width: 100%;
      padding: 8px 10px;
    }
  }
</style>
