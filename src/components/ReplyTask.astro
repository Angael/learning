---
import SessionSection from './SessionSection.astro';

type Props = {
  id: string;
  difficulty?: number;
  label?: string;
  language?: 'en' | 'pl';
};

const {
  id,
  difficulty = 3,
  label,
  language = 'en',
} = Astro.props;

const text = language === 'pl'
  ? {
      label: 'Zadanie do odpowiedzi',
      difficulty: 'trudność',
      answer: 'Twoja odpowiedź',
      placeholder: 'Wpisz tylko odpowiedzi do tego zadania.',
      copy: 'Kopiuj odpowiedź',
      copied: 'Skopiowano',
      success: 'Skopiowano identyfikator i Twoją odpowiedź. Wklej je na Discordzie.',
      failure: 'Kopiowanie nie powiodło się. Zaznacz identyfikator i odpowiedź ręcznie.',
    }
  : {
      label: 'Reply task',
      difficulty: 'difficulty',
      answer: 'Your answer',
      placeholder: 'Write only your answers to this task.',
      copy: 'Copy answer',
      copied: 'Copied',
      success: 'Copied the ID and your answer. Paste them into Discord.',
      failure: 'Copy failed. Select the ID and answer manually.',
    };

if (!/^learn:[a-z0-9./-]+(?::[a-z0-9-]+)?$/i.test(id)) {
  throw new Error(`ReplyTask id must be a stable learn: identifier; received "${id}"`);
}
if (!Number.isInteger(difficulty) || difficulty < 1 || difficulty > 5) {
  throw new Error(`ReplyTask difficulty must be an integer between 1 and 5; received ${difficulty}`);
}

const marker = `[${id}]`;
const title = `${label ?? text.label} · ${text.difficulty} ${difficulty}/5`;
---

<div
  class="reply-task"
  data-reply-task
  data-reply-id={marker}
  data-copy-label={text.copy}
  data-copy-success={text.success}
  data-copy-failure={text.failure}
  data-copied-label={text.copied}
>
  <SessionSection title={title} variant="checkpoint">
    <button slot="right" class="reply-task__copy" type="button" data-copy-trigger>{text.copy}</button>
    <div class="reply-task__content">
      <code class="reply-task__id">{marker}</code>
      <div class="reply-task__body"><slot /></div>
      <label class="reply-task__answer">
        <span>{text.answer}</span>
        <textarea data-answer placeholder={text.placeholder} rows="8"></textarea>
      </label>
      <p class="reply-task__status" data-copy-status aria-live="polite"></p>
    </div>
  </SessionSection>
</div>

<script>
  const copyFallback = (text: string, restoreFocus: HTMLElement) => {
    const input = document.createElement('textarea');
    input.value = text;
    input.setAttribute('readonly', '');
    input.style.position = 'fixed';
    input.style.opacity = '0';
    document.body.appendChild(input);
    input.select();
    const copied = document.execCommand('copy');
    input.remove();
    restoreFocus.focus();
    if (!copied) throw new Error('Copy command failed');
  };

  document.querySelectorAll<HTMLElement>('[data-reply-task]').forEach((task) => {
    const button = task.querySelector<HTMLButtonElement>('[data-copy-trigger]');
    const answer = task.querySelector<HTMLTextAreaElement>('[data-answer]');
    const status = task.querySelector<HTMLElement>('[data-copy-status]');
    if (!button || !answer || !status || button.dataset.ready === 'true') return;

    button.dataset.ready = 'true';
    button.addEventListener('click', async () => {
      const id = task.dataset.replyId ?? '';
      const response = answer.value.trim();
      const copyText = response ? `${id}\n${response}` : id;
      try {
        if (navigator.clipboard?.writeText) await navigator.clipboard.writeText(copyText);
        else copyFallback(copyText, button);
        status.textContent = task.dataset.copySuccess ?? '';
        button.textContent = task.dataset.copiedLabel ?? '';
      } catch {
        status.textContent = task.dataset.copyFailure ?? '';
        button.textContent = task.dataset.copyLabel ?? '';
      }
    });
  });
</script>

<style>
  .reply-task__content { display: grid; gap: 14px; }
  .reply-task__copy {
    padding: 9px 12px;
    border: 1px solid var(--line);
    border-radius: 10px;
    background: var(--surface, var(--bg));
    color: var(--text);
    font: inherit;
    font-weight: 700;
    cursor: pointer;
  }
  .reply-task button:hover { border-color: var(--accent); color: var(--accent); }
  .reply-task__id {
    width: fit-content;
    padding: 4px 7px;
    border-radius: 7px;
    background: var(--code);
    color: var(--code-text);
  }
  .reply-task__body { min-width: 0; }
  .reply-task__body :global(.shiki) { width: 100%; min-width: 0; }
  .reply-task__answer { display: grid; gap: 6px; font-weight: 700; }
  .reply-task__answer textarea {
    width: 100%;
    min-height: 9rem;
    resize: vertical;
    padding: 10px 12px;
    border: 1px solid var(--line);
    border-radius: 10px;
    background: var(--panel);
    color: var(--text);
    font: inherit;
    font-weight: 400;
    line-height: 1.5;
  }
  .reply-task__answer textarea:focus { border-color: var(--accent); outline: 3px solid color-mix(in srgb, var(--accent) 20%, transparent); }
  .reply-task__body :global(p:last-child),
  .reply-task__body :global(ol:last-child),
  .reply-task__body :global(ul:last-child),
  .reply-task__status { margin-bottom: 0; }
  .reply-task__status { min-height: 1.4em; font-size: .9rem; }

  @media (max-width: 759px) {
    .reply-task__content { gap: 12px; }
    .reply-task__copy { width: 100%; padding: 8px 10px; }
  }
</style>
