---
type Props = {
  id: string;
  copyText: string;
  difficulty?: number;
  label?: string;
};

const {
  id,
  copyText,
  difficulty = 3,
  label = 'Reply task',
} = Astro.props;

if (!/^learn:[a-z0-9./-]+(?::[a-z0-9-]+)?$/i.test(id)) {
  throw new Error(`ReplyTask id must be a stable learn: identifier; received "${id}"`);
}

if (!Number.isInteger(difficulty) || difficulty < 1 || difficulty > 5) {
  throw new Error(`ReplyTask difficulty must be an integer between 1 and 5; received ${difficulty}`);
}

const marker = `[${id}]`;
if (!copyText.trimStart().startsWith(marker)) {
  throw new Error(`ReplyTask copyText must start with "${marker}"`);
}
const headingId = `reply-${id.replace(/[^a-z0-9]+/gi, '-').replace(/^-|-$/g, '')}`;
---

<section class="reply-task" data-reply-task data-copy-text={copyText} aria-labelledby={headingId}>
  <div class="reply-task__header">
    <div>
      <h3 id={headingId}>{label}</h3>
      <span>Difficulty {difficulty}/5</span>
    </div>
    <button type="button" data-copy-trigger>Copy questions</button>
  </div>

  <code class="reply-task__id">{marker}</code>
  <div class="reply-task__body">
    <slot />
  </div>
  <p class="reply-task__status" data-copy-status aria-live="polite"></p>
</section>

<script>
  const copyFallback = (text: string, restoreFocus: HTMLElement) => {
    const input = document.createElement('textarea');
    input.value = text;
    input.setAttribute('readonly', '');
    input.style.position = 'fixed';
    input.style.opacity = '0';
    document.body.appendChild(input);
    input.select();
    const copied = document.execCommand('copy');
    input.remove();
    restoreFocus.focus();
    if (!copied) throw new Error('Copy command failed');
  };

  document.querySelectorAll<HTMLElement>('[data-reply-task]').forEach((task) => {
    const button = task.querySelector<HTMLButtonElement>('[data-copy-trigger]');
    const status = task.querySelector<HTMLElement>('[data-copy-status]');
    if (!button || !status || button.dataset.ready === 'true') return;

    button.dataset.ready = 'true';
    button.addEventListener('click', async () => {
      const text = task.dataset.copyText ?? '';
      try {
        if (navigator.clipboard?.writeText) {
          await navigator.clipboard.writeText(text);
        } else {
          copyFallback(text, button);
        }
        status.textContent = 'Copied. Paste this into Discord and write below each answer label.';
        button.textContent = 'Copied';
      } catch {
        status.textContent = 'Copy failed. Select the ID and questions manually.';
        button.textContent = 'Copy questions';
      }
    });
  });
</script>

<style>
  .reply-task {
    display: grid;
    gap: 14px;
    margin-top: 16px;
    padding: 18px;
    border: 1px solid color-mix(in srgb, var(--accent) 36%, var(--line));
    border-radius: 16px;
    background: var(--panel);
  }

  .reply-task__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .reply-task__header > div {
    display: grid;
    gap: 3px;
  }

  .reply-task__header h3 {
    margin: 0;
    font-size: 1rem;
  }

  .reply-task__header span {
    color: var(--muted);
    font-size: .88rem;
  }

  .reply-task button {
    padding: 9px 12px;
    border: 1px solid var(--line);
    border-radius: 10px;
    background: var(--surface, var(--bg));
    color: var(--text);
    font: inherit;
    font-weight: 700;
    cursor: pointer;
  }

  .reply-task button:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .reply-task__id {
    width: fit-content;
    padding: 4px 7px;
    border-radius: 7px;
    background: var(--code);
    color: var(--code-text);
  }

  .reply-task__body :global(p:last-child),
  .reply-task__body :global(ol:last-child),
  .reply-task__body :global(ul:last-child),
  .reply-task__status {
    margin-bottom: 0;
  }

  .reply-task__status {
    min-height: 1.4em;
    font-size: .9rem;
  }

  @media (max-width: 520px) {
    .reply-task__header {
      align-items: stretch;
      flex-direction: column;
    }

    .reply-task button {
      width: 100%;
    }
  }
</style>
