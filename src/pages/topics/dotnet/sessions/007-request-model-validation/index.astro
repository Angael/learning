---
import Callout from '../../../../../components/Callout.astro';
import Code from '../../../../../components/Code.astro';
import ReplyTask from '../../../../../components/ReplyTask.astro';
import SessionPage from '../../../../../components/SessionPage.astro';
import SessionSection from '../../../../../components/SessionSection.astro';

const endpointCode = `public record ShippingAddress(
    string Street,
    string City,
    string PostalCode);

app.MapPost("/shipping-addresses", (ShippingAddress address) =>
{
    if (string.IsNullOrWhiteSpace(address.Street))
    {
        return Results.BadRequest(new
        {
            error = "Street is required."
        });
    }

    return Results.Ok(new
    {
        accepted = true,
        city = address.City
    });
});`;

const validBody = `{
  "street": "12 Oak Street",
  "city": "Gdańsk",
  "postalCode": "80-001"
}`;

const blankBody = `{
  "street": "   ",
  "city": "Gdańsk",
  "postalCode": "80-001"
}`;

const replyText = `[learn:dotnet/007:q1]

Read the supplied code only; do not write or run a project.

Code:
