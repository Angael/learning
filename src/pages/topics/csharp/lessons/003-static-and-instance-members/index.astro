const classExample = `class Workout
{
    public string Name { get; }
    public int Minutes { get; }

    public Workout(string name, int minutes)
    {
        Name = name;
        Minutes = minutes;
    }

    public string Describe()
    {
        return $"{Name}: {Minutes} minutes";
    }

    public static bool IsLong(int minutes)
    {
        return minutes >= 40;
    }
}`;

const validCalls = `var walk = new Workout("Walk", 45);
var run = new Workout("Run", 25);

Console.WriteLine(walk.Describe());
Console.WriteLine(run.Describe());
Console.WriteLine(Workout.IsLong(walk.Minutes));
Console.WriteLine(Workout.IsLong(run.Minutes));`;

const taskCode = `var swim = new Workout("Swim", 50);

Console.WriteLine(swim.Describe());
Console.WriteLine(Workout.IsLong(swim.Minutes));

Workout.Describe();
swim.IsLong(20);`;

