---
const integerDivision = `var x = 5;
var y = 2;

Console.WriteLine(x / y); // 2`;

const numericDefaults = `var a = 5;    // int
var b = 5.0;  // double
var c = 5f;   // float
var d = 5m;   // decimal
var e = "5";  // string`;

const mixedDecimalDouble = `var price = 10m; // decimal
var tax = 0.23;   // double

Console.WriteLine(price * tax); // compile-time error`;

const fixedDecimal = `var price = 10m;
var tax = 0.23m;

Console.WriteLine(price * tax); // 2.30`;

const mixedIntDouble = `var count = 5;     // int
var total = 2.0;   // double
var result = count / total;

Console.WriteLine(result); // 2.5`;
