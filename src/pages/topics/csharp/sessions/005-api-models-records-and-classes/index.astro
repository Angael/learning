const exampleCode = `public sealed record Currency(string Code, int DecimalPlaces);

public sealed class GiftCard
{
    public string Code { get; }
    public decimal RemainingBalance { get; private set; }

    public GiftCard(string code, decimal openingBalance)
    {
        Code = code;
        RemainingBalance = openingBalance;
    }

    public bool Spend(decimal amount)
    {
        if (amount <= 0 || amount > RemainingBalance) return false;

        RemainingBalance -= amount;
        return true;
    }
}`;

const replyText = `[learn:csharp/005:q1]

A. Read this record syntax:
\`public record ShippingAddress(string Street, string City, string PostalCode);\`
- What is the type name?
- Name one property it creates.
- Why does a record fit an address here? (one short phrase)

B. Read this property:
\`public string Status { get; private set; }\`
- What can any caller do because of \`get\`?
- Who can change \`Status\` because of \`private set\`?
- Why is that useful for a parcel status? (one short phrase)

C. One final choice
- Would you use a record or a class for a parcel whose status changes? Why? (one short phrase)`;
---

<SessionPage
  title="Session 5 · C# API models: records and classes"
  heading="Model fixed request data and guarded domain state"
  lede="Today’s win: choose a record for a fixed API-shaped value and a class for an object whose state may change only through one explicit rule."
  backHref="/topics/csharp/"
  backLabel="C# sessions"
>
  <SessionSection title="One design question, not a receiver drill">
    <Callout>
      Start from behaviour: is this value fixed once supplied, or does it have a lifecycle with permitted state changes? That decision shapes the public API.
    </Callout>
    <p>
      In a small backend system, a request usually describes data supplied at one moment. A domain object may instead hold state that changes under a rule. Both can have properties; the important difference is what callers are allowed to change.
    </p>
  </SessionSection>

  <SessionSection title="Worked example: a fixed value and a guarded balance">
    <Code code={exampleCode} lang="csharp" />
    <ul>
      <li><code>Currency</code> is a positional <code>record</code>: a compact fixed description with init-only public values in this model.</li>
      <li><code>GiftCard</code> is a <code>class</code>: it has a balance that changes only through <code>Spend</code>.</li>
      <li><code>RemainingBalance</code> is public to read but has <code>private set;</code>, so a caller cannot bypass the rule by assigning a new balance.</li>
    </ul>
    <Callout>Do not turn this into “records are immutable” or “classes are mutable.” Either kind of type can be designed differently. Here the choice expresses this particular API and lifecycle.</Callout>
  </SessionSection>

  <SessionSection title="The only distinction to keep today">
    <ul>
      <li><code>public record ShippingAddress(...)</code> declares a type named <code>ShippingAddress</code>. Its positional values become properties such as <code>Street</code>.</li>
      <li>Use a <code>record</code> for a small value-shaped description, such as an address that is supplied as a whole.</li>
      <li>Use a <code>class</code> when an object has a changing lifecycle, such as a parcel whose status changes.</li>
      <li><code>{`{ get; private set; }`}</code> means everyone can read the property, but only code inside that class can change it. That prevents callers from setting a parcel status however they like.</li>
    </ul>
  </SessionSection>

  <ReplyTask id="learn:csharp/005:q1" copyText={replyText} difficulty={3}>
    <p><strong>Phone-friendly version:</strong> do not write code, an application, or <code>Main</code>. Reply with six very short answers—single words or short phrases are enough.</p>
    <ol>
      <li>Read the positional <code>ShippingAddress</code> record below. Identify its type name, one generated property, and why this kind of fixed address data can be a record.</li>
      <li>Read <code>Status {`{ get; private set; }`}</code>. Say what <code>get</code> lets callers do, who may use the setter, and why that protects a parcel’s status.</li>
      <li>Choose <code>record</code> or <code>class</code> for a parcel whose status changes, with one short reason.</li>
    </ol>
    <Code code={`public record ShippingAddress(string Street, string City, string PostalCode);

public string Status { get; private set; }`} lang="csharp" />
  </ReplyTask>
</SessionPage>
