const classExample = `class RetryTracker
{
    public string Operation { get; }
    public int MaxAttempts { get; }
    public int Attempts { get; private set; }

    public RetryTracker(string operation, int maxAttempts)
    {
        Operation = operation;
        MaxAttempts = maxAttempts;
        Attempts = 0;
    }

    public bool RecordAttempt()
    {
        if (Attempts >= MaxAttempts)
        {
            return false;
        }

        Attempts++;
        return true;
    }

    public static bool IsValidMaxAttempts(int maxAttempts)
    {
        return maxAttempts > 0;
    }
}`;

const taskCode = `var email = new RetryTracker("send-email", 3);
var webhook = new RetryTracker("post-webhook", 1);

Console.WriteLine(email.RecordAttempt());
Console.WriteLine(email.Attempts);
Console.WriteLine(webhook.Attempts);

RetryTracker.RecordAttempt();
email.IsValidMaxAttempts(2);`;

