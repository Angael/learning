---
import LessonList from '../components/LessonList.astro';
import PageShell from '../components/PageShell.astro';
import { topics } from '../data/catalog';

const lessonNumber = (href: string) => href.match(/lessons\/(\d+)/)?.[1] ?? '';
const sortedLessons = <T extends { href: string; date?: string }>(lessons: T[]) => [...lessons].sort((a, b) => {
  const dateCompare = (b.date ?? '').localeCompare(a.date ?? '');
  if (dateCompare !== 0) return dateCompare;
  return lessonNumber(b.href).localeCompare(lessonNumber(a.href));
});
---

<PageShell title="Learning" heading="Learning" summary="Topics and lessons. The index is for routing: every published lesson should be reachable from here.">
  {topics.map((topic) => {
    const lessons = sortedLessons(topic.lessons);
    const visibleLessons = lessons.slice(0, 3);
    const hiddenCount = Math.max(0, lessons.length - visibleLessons.length);

    return (
      <section class="topic" aria-labelledby={`${topic.slug}-title`}>
        <div class="topic-title">
          <a id={`${topic.slug}-title`} href={topic.href}>{topic.title}</a>
          <span>{topic.lessons.length} lessons</span>
        </div>
        <p>{topic.summary}</p>

        <div class="lesson-list-wrap">
          <LessonList lessons={visibleLessons} />
          {hiddenCount > 0 && (
            <a class="view-all-link" href={topic.href}>View all {topic.lessons.length} {topic.title} lessons →</a>
          )}
        </div>
      </section>
    );
  })}
</PageShell>

<style>
  .topic {
    padding: 20px 0;
    border-top: 1px solid var(--line);
  }

  .topic-title {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 6px;
  }

  .topic-title a {
    font-size: 1.35rem;
    font-weight: 750;
    letter-spacing: -.03em;
  }

  .topic-title span {
    color: var(--muted);
    font-size: .95rem;
    white-space: nowrap;
  }

  .lesson-list-wrap {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-top: 18px;
  }

  .view-all-link {
    align-self: flex-start;
    color: var(--link);
    font-weight: 650;
  }
</style>
