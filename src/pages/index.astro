---
const topics = [
  ['Astro web', 'Build, route, style, debug, and explain this site.'],
  ['Dokploy deployment', 'Containerize, deploy, inspect logs, and operate the app.'],
  ['German', 'Practical German with spaced retrieval and tiny conversations.'],
  ['Dinner', 'Plan and cook dinners from constraints, technique, and taste.'],
  ['.NET', 'C# and ASP.NET Core from runtime model to deployable APIs.'],
  ['SSO', 'OAuth, OIDC, SAML, sessions, tokens, and production debugging.'],
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Angeal's Learning Lab</title>
    <style>
      :root { color-scheme: dark; --bg:#0b1020; --card:#151b31; --text:#f8fbff; --muted:#b7c3df; --accent:#8bd5ff; --accent2:#f5a3ff; --line:rgba(255,255,255,.13); }
      * { box-sizing: border-box; }
      body { margin:0; font-family:Inter,ui-sans-serif,system-ui,sans-serif; color:var(--text); background: radial-gradient(circle at 20% 0%, rgba(139,213,255,.22), transparent 28rem), radial-gradient(circle at 100% 80%, rgba(245,163,255,.15), transparent 28rem), var(--bg); }
      main { width:min(1120px, calc(100% - 32px)); margin:0 auto; padding:72px 0; }
      .hero { display:grid; grid-template-columns:1.2fr .8fr; gap:24px; align-items:stretch; }
      .card { border:1px solid var(--line); border-radius:28px; padding:32px; background:linear-gradient(145deg, rgba(21,27,49,.94), rgba(28,36,66,.72)); box-shadow:0 24px 80px rgba(0,0,0,.28); }
      .eyebrow { margin:0 0 14px; color:var(--accent); text-transform:uppercase; letter-spacing:.16em; font-size:.78rem; font-weight:800; }
      h1 { margin:0; max-width:11ch; font-size:clamp(3.2rem,8vw,6.8rem); line-height:.9; letter-spacing:-.075em; }
      h2 { margin:0 0 12px; }
      p { color:var(--muted); line-height:1.7; }
      .mission { max-width:66ch; font-size:1.08rem; }
      .grid { display:grid; grid-template-columns:repeat(3, minmax(0, 1fr)); gap:16px; margin-top:24px; }
      .topic { border:1px solid var(--line); border-radius:22px; padding:22px; background:rgba(255,255,255,.045); }
      .topic h3 { margin:0 0 8px; }
      .topic p { margin:0; }
      ul { margin:0; padding-left:1.2rem; color:var(--muted); line-height:1.8; }
      code { color:var(--accent); background:rgba(139,213,255,.10); padding:.15rem .35rem; border-radius:.35rem; }
      .note { margin-top:24px; border-left:4px solid var(--accent2); border-radius:14px; padding:18px 20px; background:rgba(245,163,255,.08); }
      @media (max-width: 820px) { main { padding:40px 0; } .hero,.grid { grid-template-columns:1fr; } }
    </style>
  </head>
  <body>
    <main>
      <section class="hero">
        <div class="card">
          <p class="eyebrow">Astro • Docker • Dokploy-ready</p>
          <h1>Learn by building.</h1>
          <p class="mission">A durable learning lab where each topic has a plan, each lesson requires participation, and every useful insight leaves notes for the next session.</p>
        </div>
        <aside class="card">
          <h2>Teacher contract</h2>
          <ul>
            <li>First principles before labels.</li>
            <li>One small lesson at a time.</li>
            <li>Retrieval and practice before passive explanation.</li>
            <li>Progress is recorded in the repository.</li>
          </ul>
        </aside>
      </section>

      <section class="grid" aria-label="Learning topics">
        {topics.map(([title, description]) => (
          <article class="topic">
            <h3>{title}</h3>
            <p>{description}</p>
          </article>
        ))}
      </section>

      <p class="note">For local verification run <code>npm run build</code>. For Dokploy, build the included Dockerfile and serve port <code>80</code>.</p>
    </main>
  </body>
</html>
