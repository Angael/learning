---
const modules = [
  {
    title: 'Astro fundamentals',
    description: 'Pages, islands, components, content collections, and deployable static output.',
  },
  {
    title: 'Web platform basics',
    description: 'HTML semantics, CSS layout, accessibility, forms, fetch, and browser debugging.',
  },
  {
    title: 'Backend-adjacent skills',
    description: 'APIs, auth concepts, environment variables, databases, queues, and deployment tradeoffs.',
  },
  {
    title: 'Operations for Dokploy',
    description: 'Build artifacts, Docker mental models, reverse proxies, domains, logs, and rollback practice.',
  },
];

const principles = [
  'Start from first principles, then name abstractions only after the need is felt.',
  'Use tiny lessons with one concrete win and one retrieval check.',
  'Make hidden expert thinking visible before asking for independent work.',
  'Prefer real projects over toy drills, but keep each practice loop small.',
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Astro Learning Lab</title>
    <style>
      :root {
        color-scheme: dark;
        --bg: #0e1020;
        --panel: #171a2f;
        --panel-strong: #202644;
        --text: #f4f6ff;
        --muted: #b8c0df;
        --accent: #8bd5ff;
        --accent-2: #f5a3ff;
        --line: rgba(255, 255, 255, 0.12);
      }

      * { box-sizing: border-box; }

      body {
        margin: 0;
        min-height: 100vh;
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        background:
          radial-gradient(circle at top left, rgba(139, 213, 255, 0.20), transparent 34rem),
          radial-gradient(circle at bottom right, rgba(245, 163, 255, 0.16), transparent 30rem),
          var(--bg);
        color: var(--text);
      }

      main {
        width: min(1100px, calc(100% - 32px));
        margin: 0 auto;
        padding: 72px 0;
      }

      .hero {
        display: grid;
        gap: 28px;
        grid-template-columns: minmax(0, 1.3fr) minmax(280px, 0.7fr);
        align-items: stretch;
      }

      .card {
        border: 1px solid var(--line);
        border-radius: 28px;
        background: linear-gradient(145deg, rgba(23, 26, 47, 0.92), rgba(32, 38, 68, 0.72));
        box-shadow: 0 24px 80px rgba(0, 0, 0, 0.28);
        padding: 32px;
      }

      .eyebrow {
        margin: 0 0 12px;
        color: var(--accent);
        font-weight: 800;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        font-size: 0.78rem;
      }

      h1 {
        margin: 0;
        max-width: 12ch;
        font-size: clamp(3.2rem, 8vw, 6.8rem);
        letter-spacing: -0.08em;
        line-height: 0.9;
      }

      h2 { margin: 0 0 16px; font-size: 1.45rem; }
      p { color: var(--muted); line-height: 1.7; }

      .mission {
        margin-top: 24px;
        max-width: 68ch;
        font-size: 1.08rem;
      }

      .grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 16px;
        margin-top: 28px;
      }

      .module {
        border: 1px solid var(--line);
        border-radius: 20px;
        padding: 20px;
        background: rgba(255, 255, 255, 0.045);
      }

      .module h3 { margin: 0 0 8px; }
      .module p { margin: 0; font-size: 0.95rem; }

      ol {
        margin: 0;
        padding-left: 1.2rem;
        color: var(--muted);
        line-height: 1.8;
      }

      .footer-note {
        margin-top: 32px;
        padding: 18px 20px;
        border-left: 4px solid var(--accent-2);
        border-radius: 12px;
        background: rgba(245, 163, 255, 0.08);
      }

      code {
        color: var(--accent);
        background: rgba(139, 213, 255, 0.10);
        padding: 0.15rem 0.35rem;
        border-radius: 0.35rem;
      }

      @media (max-width: 820px) {
        main { padding: 40px 0; }
        .hero, .grid { grid-template-columns: 1fr; }
      }
    </style>
  </head>
  <body>
    <main>
      <section class="hero">
        <div class="card">
          <p class="eyebrow">Learning project • Astro first</p>
          <h1>Build to learn.</h1>
          <p class="mission">
            This repository is a deployable Astro lab for learning web development, operations,
            AI-assisted study habits, and anything else worth turning into small, durable lessons.
          </p>
        </div>
        <aside class="card">
          <h2>How the teacher should work</h2>
          <ol>
            {principles.map((principle) => <li>{principle}</li>)}
          </ol>
        </aside>
      </section>

      <section class="grid" aria-label="Learning modules">
        {modules.map((module) => (
          <article class="module">
            <h3>{module.title}</h3>
            <p>{module.description}</p>
          </article>
        ))}
      </section>

      <p class="footer-note">
        Next: deploy this with Dokploy after the first real lesson lands. For local work, run
        <code>npm run dev</code>. For production verification, run <code>npm run build</code>.
      </p>
    </main>
  </body>
</html>
